# Postgres (Drizzle ORM) — Supabase pooler URL or any Postgres host
# Uses the postgres role; bypasses Supabase RLS (server-side only — keep this secret)
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# Admin login password for /admin
ADMIN_PASSWORD=your-secure-password

# After first deploy, run: bun run db:migrate:rls
# Enables Row Level Security on invitation + rsvp_responses in Supabase
